# Copy to `.env` in this folder for local CLI testing, or let install.ps1 write
# %ProgramData%\AMSBioSync\.env for the Windows service (preferred on production).

# Neon Postgres connection string for the AMS database (required).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Full path to the AttendanceTracker 11.8 Access database on the Windows machine.
EBIO_MDB_PATH=C:\Users\shara\Desktop\AMT\attendance_db.mdb

# Jet/ACE database password for attendance_db.mdb.
EBIO_MDB_PASSWORD=attendance@123

# Timezone the biometric machine records punches in (naive local timestamps).
EBIO_TIMEZONE=Asia/Karachi

# Seconds between automatic sync passes (Windows service default: 900 = 15 minutes).
EBIO_SYNC_INTERVAL=900

# Company slugs in Neon to match employees against (comma-separated).
EBIO_COMPANY_SLUGS=xorora,crest-led

# Company slug used when auto-creating employees with no match (defaults to first slug above).
EBIO_NEW_EMPLOYEE_COMPANY_SLUG=xorora

# Email domains for auto-generated employee emails (by company slug).
EBIO_EMAIL_DOMAIN_XORORA=xorora.com
EBIO_EMAIL_DOMAIN_CREST_LED=crestled.com

# Fuzzy name match threshold 0–100 (rapidfuzz token_sort_ratio; default 85).
EBIO_NAME_MATCH_THRESHOLD=85

# Rows per upsert batch (optional).
EBIO_BATCH_SIZE=500

# Set to 1/true/yes for debug logging in the Windows service.
# EBIO_VERBOSE=true

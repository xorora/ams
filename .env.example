# Copy to .env.local for local development (never commit secrets).
# On Vercel, set the same keys in Project → Settings → Environment Variables.

# --- Database (Neon) ---
DATABASE_URL=

# --- Auth.js ---
AUTH_URL=http://localhost:3000
AUTH_SECRET=

# --- Google OAuth (Workspace) — required ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_WORKSPACE_HD=

# --- Office geofence — required; seeds office_settings on first use ---
OFFICE_LAT=
OFFICE_LNG=
OFFICE_RADIUS_METERS=100

# --- Vercel Cron (auto-absent job) ---
CRON_SECRET=

# --- Bootstrap (optional, one-time) ---
BOOTSTRAP_ADMIN_EMAIL=
